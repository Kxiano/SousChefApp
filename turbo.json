{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "GEMINI_API_KEY",
    "DATABASE_URL",
    "DATABASE_URL_PREVIEW",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "RESEND_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
